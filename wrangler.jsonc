{
  // Static site: Next.js `output: "export"` writes prerendered files to ./out,
  // which Cloudflare Workers serves as static assets. No Worker script needed.
  "name": "oleary-labs-site",
  "compatibility_date": "2026-07-13",
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page"
  }
}
